---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Rankings" active="rankings"><div class="header"><div><h1>Rankings</h1><div class="muted">Explore the top players across key World Cup performance metrics.</div></div><select id="sort" class="select"><option value="goals">Goals</option><option value="assists">Assists</option><option value="rating">Average rating</option><option value="matches">Matches played</option></select></div><div class="card"><div class="table-wrap"><table><thead><tr><th>Rank</th><th>Player</th><th>Team</th><th>Position</th><th>Matches</th><th>Goals</th><th>Assists</th><th>Avg. rating</th></tr></thead><tbody id="rows"></tbody></table></div></div><script define:vars={{ api: import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api" }}>
const esc=v=>String(v??"—").replace(/[&<>'"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[c]));
const codes={Australia:"AU",Argentina:"AR",Belgium:"BE",Brazil:"BR",Cameroon:"CM",Canada:"CA",Chile:"CL",China:"CN",Colombia:"CO","Costa Rica":"CR",Croatia:"HR",Denmark:"DK",Ecuador:"EC",Egypt:"EG",England:"GB",France:"FR",Germany:"DE",Ghana:"GH",Iran:"IR",Iraq:"IQ",Italy:"IT",Jamaica:"JM",Japan:"JP",Mexico:"MX",Morocco:"MA",Netherlands:"NL",Nigeria:"NG",Panama:"PA",Paraguay:"PY",Peru:"PE",Poland:"PL",Portugal:"PT",Qatar:"QA","Saudi Arabia":"SA",Senegal:"SN","South Africa":"ZA","South Korea":"KR",Spain:"ES",Sweden:"SE",Switzerland:"CH",Tunisia:"TN",Turkey:"TR",Ukraine:"UA",Uruguay:"UY",USA:"US","United States":"US",Wales:"GB"};
function flag(name){const c=codes[name];return c?String.fromCodePoint(...[...c].map(x=>127397+x.charCodeAt())):"🌐"}function initials(n){return String(n||"").split(" ").slice(0,2).map(x=>x[0]).join("").toUpperCase()}function ratingClass(v){v=Number(v||0);return v>=8?"rating-excellent":v>=7?"rating-good":v>=6?"rating-average":"rating-poor"}
async function load(){const r=await fetch(`${api}/rankings?sort=${document.getElementById("sort").value}&limit=50`);const d=await r.json();document.getElementById("rows").innerHTML=d.map((v,i)=>`<tr><td class="rank">${i+1}</td><td><div class="rank-player"><div class="rank-avatar">${esc(initials(v.player_name))}</div><div><div class="player-name">${esc(v.player_name)}</div><div class="player-sub"><span class="flag">${flag(v.team)}</span> ${esc(v.team)}</div></div></div></td><td><span class="country"><span class="flag">${flag(v.team)}</span>${esc(v.team)}</span></td><td><span class="position-badge">${esc(v.position)}</span></td><td>${v.matches_played}</td><td><strong>${v.total_goals}</strong></td><td>${v.total_assists}</td><td><span class="rating ${ratingClass(v.average_rating)}">${esc(v.average_rating)}</span></td></tr>`).join("")}document.getElementById("sort").onchange=load;load();
</script></Layout>
