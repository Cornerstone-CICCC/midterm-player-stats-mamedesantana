---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
const { id } = Astro.params;
---

<Layout title="Performance details"
    ><div class="header">
        <div>
            <a class="muted" href="/">← Back to Performances</a><h1
                style="margin-top:8px"
            >
                Performance Details
            </h1>
        </div><div class="toolbar">
            <a class="btn btn-secondary" href={`/performances/${id}/edit`}
                >Edit</a
            ><button id="delete" class="btn btn-danger">Delete</button>
        </div>
    </div><div id="status" class="status"></div><div id="content">
        <div class="card empty">Loading...</div>
    </div>
    <script
        define:vars={{
            id,
            api: import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api",
        }}
    >
        const content = document.getElementById("content"),
            status = document.getElementById("status");
        const codes = {
            Spain: "ES",
            France: "FR",
            Brazil: "BR",
            Argentina: "AR",
            Morocco: "MA",
            Portugal: "PT",
            England: "GB",
            Germany: "DE",
            Italy: "IT",
            Netherlands: "NL",
            Denmark: "DK",
            "South Africa": "ZA",
            Canada: "CA",
            USA: "US",
            "United States": "US",
            Mexico: "MX",
            Japan: "JP",
            "South Korea": "KR",
            Australia: "AU",
        };
        const flag = (n) =>
            codes[n]
                ? String.fromCodePoint(
                      ...[...codes[n]].map((x) => 127397 + x.charCodeAt()),
                  )
                : "🌐";
        const ratingClass = (v) =>
            Number(v) >= 8
                ? "rating-excellent"
                : Number(v) >= 7
                  ? "rating-good"
                  : Number(v) >= 6
                    ? "rating-average"
                    : "rating-poor";
        const esc = (v) =>
            String(v ?? "—").replace(
                /[&<>'"]/g,
                (c) =>
                    ({
                        "&": "&amp;",
                        "<": "&lt;",
                        ">": "&gt;",
                        "'": "&#39;",
                        '"': "&quot;",
                    })[c],
            );
        const item = (k, v) =>
            `<div class="field"><label>${k}</label><div>${k.toLowerCase().includes("rating") ? `<span class="rating ${ratingClass(v)}">${esc(v)}</span>` : esc(v)}</div></div>`;
        async function load() {
            const r = await fetch(`${api}/performances/${id}`);
            if (!r.ok) {
                content.innerHTML =
                    '<div class="card empty">Performance not found.</div>';
                return;
            }
            const p = await r.json();
            const initials = p.player_name
                .split(" ")
                .slice(0, 2)
                .map((x) => x[0])
                .join("");
            content.innerHTML = `<div class="card hero"><div class="avatar">${esc(initials)}</div><div class="hero-meta"><h2>${esc(p.player_name)}</h2><div class="muted">#${esc(p.jersey_number)} · ${esc(p.position)}</div><div class="hero-line"><span class="country"><span class="flag">${flag(p.team)}</span>${esc(p.team)}</span><span>${esc(p.opponent_team)} · ${new Date(p.match_date).toLocaleDateString("en-CA")}</span><span>${esc(p.stadium)}</span></div></div></div><div class="grid" style="margin-top:18px">${section(
                "Attacking",
                [
                    ["Goals", p.goals],
                    ["Assists", p.assists],
                    ["Shots", p.shots],
                    ["Shots on target", p.shots_on_target],
                    ["xG", p.expected_goals_xg],
                    ["xA", p.expected_assists_xa],
                    ["Key passes", p.key_passes],
                    [
                        "Pass accuracy",
                        Math.round(Number(p.pass_accuracy || 0) * 100) + "%",
                    ],
                ],
            )}${section("Defensive", [
                ["Tackles", p.tackles],
                ["Interceptions", p.interceptions],
                ["Clearances", p.clearances],
                ["Blocks", p.blocks],
                ["Recoveries", p.recoveries],
                ["Fouls committed", p.fouls_committed],
                ["Yellow cards", p.yellow_cards],
                ["Red cards", p.red_cards],
            ])}${section("Physical", [
                ["Minutes played", p.minutes_played],
                ["Distance covered", p.distance_covered_km + " km"],
                ["Sprint distance", p.sprint_distance_km + " km"],
                ["Top speed", p.top_speed_kmh + " km/h"],
                ["Accelerations", p.accelerations],
                ["Decelerations", p.decelerations],
                ["Stamina", p.stamina_score],
            ])}${section("Ratings", [
                ["Player rating", p.player_rating],
                ["Performance score", p.performance_score],
                ["Offensive contribution", p.offensive_contribution],
                ["Defensive contribution", p.defensive_contribution],
                ["Possession impact", p.possession_impact],
                ["Creativity", p.creativity_score],
                ["Consistency", p.consistency_score],
            ])}</div>`;
        }
        function section(title, values) {
            return `<div class="card section"><h2>${title}</h2><div class="form-grid">${values.map(([k, v]) => item(k, v)).join("")}</div></div>`;
        }
        document.getElementById("delete").onclick = async () => {
            if (!confirm("Delete this performance?")) return;
            const r = await fetch(`${api}/performances/${id}`, {
                method: "DELETE",
            });
            if (r.ok) location.href = "/";
            else {
                status.className = "status show error";
                status.textContent = "Could not delete the performance.";
            }
        };
        load();
    </script></Layout
>
