---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Player Performances"
    ><div class="header">
        <h1>Player Performances</h1><a
            class="btn btn-primary"
            href="/performances/new">＋ Add Performance</a>
    </div>
    <div class="toolbar" style="margin-bottom:16px">
        <input
            id="search"
            class="input"
            placeholder="Search player, team, position..."
        /><select id="team" class="select"
            ><option value="">All teams</option></select
        ><select id="position" class="select"
            ><option value="">All positions</option></select
        ><select id="sort" class="select"
            ><option value="match_date">Match date</option><option
                value="player_name">Player name</option
            ><option value="goals">Goals</option><option value="assists"
                >Assists</option
            ><option value="player_rating">Rating</option></select
        ><select id="order" class="select"
            ><option value="desc">Descending</option><option value="asc"
                >Ascending</option
            ></select>
    </div>
    <div id="status" class="status"></div><div class="card">
        <div class="table-wrap">
            <table>
                <thead
                    ><tr
                        ><th>Player</th><th>Team</th><th>Opponent</th><th
                            >Match date</th
                        ><th>Position</th><th>Min</th><th>Goals</th><th
                            >Assists</th
                        ><th>Shots</th><th>Pass accuracy</th><th>Rating</th></tr
                    ></thead
                ><tbody id="rows"></tbody>
            </table>
        </div><div class="pager">
            <div>
                Show <select id="limit" class="select"
                    ><option>10</option><option selected>25</option><option
                        >50</option
                    ><option>100</option></select
                > entries · <span id="range"></span>
            </div><div class="pager-buttons">
                <button id="prev">‹ Previous</button><span id="pageInfo"
                ></span><button id="next">Next ›</button>
            </div>
        </div>
    </div>
    <script
        define:vars={{
            api: import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api",
        }}
    >
        let page = 1,
            timer;
        const $ = (id) => document.getElementById(id);
        const state = () => ({
            search: $("search").value,
            team: $("team").value,
            position: $("position").value,
            sort: $("sort").value,
            order: $("order").value,
            limit: $("limit").value,
        });
        function esc(v) {
            return String(v ?? "").replace(
                /[&<>'"]/g,
                (c) =>
                    ({
                        "&": "&amp;",
                        "<": "&lt;",
                        ">": "&gt;",
                        "'": "&#39;",
                        '"': "&quot;",
                    })[c],
            );
        }
        function date(v) {
            return v ? new Date(v).toLocaleDateString("en-CA") : "—";
        }
        function initials(n) {
            return String(n || "")
                .split(" ")
                .slice(0, 2)
                .map((x) => x[0])
                .join("")
                .toUpperCase();
        }
        const codes = {
            Australia: "AU",
            Argentina: "AR",
            Belgium: "BE",
            Brazil: "BR",
            Cameroon: "CM",
            Canada: "CA",
            Chile: "CL",
            China: "CN",
            Colombia: "CO",
            "Costa Rica": "CR",
            Croatia: "HR",
            Denmark: "DK",
            Ecuador: "EC",
            Egypt: "EG",
            England: "GB",
            France: "FR",
            Germany: "DE",
            Ghana: "GH",
            Iran: "IR",
            Iraq: "IQ",
            Italy: "IT",
            Jamaica: "JM",
            Japan: "JP",
            Mexico: "MX",
            Morocco: "MA",
            Netherlands: "NL",
            Nigeria: "NG",
            Panama: "PA",
            Paraguay: "PY",
            Peru: "PE",
            Poland: "PL",
            Portugal: "PT",
            Qatar: "QA",
            "Saudi Arabia": "SA",
            Senegal: "SN",
            "South Africa": "ZA",
            "South Korea": "KR",
            Spain: "ES",
            Sweden: "SE",
            Switzerland: "CH",
            Tunisia: "TN",
            Turkey: "TR",
            Ukraine: "UA",
            Uruguay: "UY",
            USA: "US",
            "United States": "US",
            Wales: "GB",
        };
        function flag(name) {
            const c = codes[name];
            return c
                ? String.fromCodePoint(
                      ...[...c].map((x) => 127397 + x.charCodeAt()),
                  )
                : "🌐";
        }
        function ratingClass(v) {
            v = Number(v || 0);
            return v >= 8
                ? "rating-excellent"
                : v >= 7
                  ? "rating-good"
                  : v >= 6
                    ? "rating-average"
                    : "rating-poor";
        }
        async function loadFilters() {
            const r = await fetch(`${api}/filters`);
            if (!r.ok) return;
            const d = await r.json();
            d.teams.forEach((v) =>
                $("team").insertAdjacentHTML(
                    "beforeend",
                    `<option>${esc(v)}</option>`,
                ),
            );
            d.positions.forEach((v) =>
                $("position").insertAdjacentHTML(
                    "beforeend",
                    `<option>${esc(v)}</option>`,
                ),
            );
        }
        async function load() {
            const q = new URLSearchParams({ ...state(), page: String(page) });
            const r = await fetch(`${api}/performances?${q}`);
            if (!r.ok) {
                $("status").className = "status show error";
                $("status").textContent = "Could not load performances.";
                return;
            }
            const x = await r.json();
            $("rows").innerHTML =
                x.data
                    .map(
                        (v) =>
                            `<tr data-id="${v.id}"><td><div class="player-cell"><div class="mini-avatar">${esc(initials(v.player_name))}</div><div><div class="player-name">${esc(v.player_name)}</div><div class="player-sub">#${esc(v.jersey_number ?? "—")} · ${esc(v.position)}</div></div></div></td><td><span class="country"><span class="flag">${flag(v.team)}</span>${esc(v.team)}</span></td><td><span class="country"><span class="flag">${flag(v.opponent_team)}</span>${esc(v.opponent_team)}</span></td><td>${date(v.match_date)}</td><td><span class="position-badge">${esc(v.position)}</span></td><td>${esc(v.minutes_played)}</td><td>${esc(v.goals)}</td><td>${esc(v.assists)}</td><td>${esc(v.shots)}</td><td>${Math.round(Number(v.pass_accuracy || 0) * 100)}%</td><td><span class="rating ${ratingClass(v.player_rating)}">${esc(v.player_rating)}</span></td></tr>`,
                    )
                    .join("") ||
                `<tr><td colspan="11" class="empty">No records found</td></tr>`;
            document
                .querySelectorAll("tbody tr[data-id]")
                .forEach((tr) =>
                    tr.addEventListener(
                        "click",
                        () =>
                            (location.href = `/performances/${tr.dataset.id}`),
                    ),
                );
            const p = x.pagination;
            $("range").textContent = p.totalRecords
                ? `${(p.page - 1) * p.limit + 1}–${Math.min(p.page * p.limit, p.totalRecords)} of ${p.totalRecords}`
                : "0 records";
            $("pageInfo").textContent =
                `Page ${p.page} of ${p.totalPages || 1}`;
            $("prev").disabled = p.page <= 1;
            $("next").disabled = p.page >= p.totalPages;
        }
        ["team", "position", "sort", "order", "limit"].forEach((id) =>
            $(id).addEventListener("change", () => {
                page = 1;
                load();
            }),
        );
        $("search").addEventListener("input", () => {
            clearTimeout(timer);
            timer = setTimeout(() => {
                page = 1;
                load();
            }, 300);
        });
        $("prev").onclick = () => {
            page--;
            load();
        };
        $("next").onclick = () => {
            page++;
            load();
        };
        loadFilters();
        load();
    </script></Layout
>
